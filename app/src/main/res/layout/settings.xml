<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══════════ 头部 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cesia 输入法"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0"
                android:textSize="12sp"
                android:textColor="#81D8D0"
                android:background="#E0F7F5"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- ═══════════ 统计卡片 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_tiffany"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 使用统计"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#81D8D0"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_input_chars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#81D8D0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输入字数"
                        android:textSize="10sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_output_chars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#81D8D0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="返回字数"
                        android:textSize="10sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#81D8D0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="润色次数"
                        android:textSize="10sp"
                        android:textColor="#999999" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 语音统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_tiffany"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙️ 语音统计"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#81D8D0"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_voice_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0分钟"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#81D8D0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="语音时长"
                        android:textSize="10sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_saved_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0分钟"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#81D8D0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="节省时间"
                        android:textSize="10sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_voice_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0字/分"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#81D8D0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输入速度"
                        android:textSize="10sp"
                        android:textColor="#999999" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 历史记录按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_history"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="📜 查看历史记录"
            android:textSize="13sp"
            android:textColor="#81D8D0"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#81D8D0"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            android:layout_marginBottom="16dp" />

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- ═══════════ 润色 API ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔗 润色 API"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API URL"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_api_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textSize="12sp"
                android:text="https://openrouter.ai/api/v1/chat/completions" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="OpenRouter API Key"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_openrouter_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Groq API Key（云端语音）"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_groq_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 云端模型 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="云端 AI 模型"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_cloud_model"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="2dp"
            android:padding="8dp"
            android:background="@android:drawable/btn_dropdown" />

        <TextView
            android:id="@+id/tv_model_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#999999"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tavily API Key（互联网搜索）"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_brave_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI 润色 Prompt"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_polish_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 语音命令词 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙️ 语音命令词"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="退出"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="#81D8D0"
                app:hintTextColor="#81D8D0"
                android:layout_marginEnd="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cmd_exit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="润色"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="#81D8D0"
                app:hintTextColor="#81D8D0"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cmd_polish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="结束"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="#81D8D0"
                app:hintTextColor="#81D8D0"
                android:layout_marginStart="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cmd_finish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="发送"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="#81D8D0"
                app:hintTextColor="#81D8D0"
                android:layout_marginEnd="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cmd_send"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="指令"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="#81D8D0"
                app:hintTextColor="#81D8D0"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cmd_command"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="写作"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="#81D8D0"
                app:hintTextColor="#81D8D0"
                android:layout_marginStart="2dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cmd_writing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_command_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#999999"
            android:padding="4dp"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 个性化 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ 个性化"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="初始状态文字"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="4dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_status_idle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="智能写作按钮文字"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="4dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_smart_writing_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="魔法书弹窗标题"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_magic_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 测试区 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧪 测试"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="输入要润色的文本"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_test_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top"
                android:textSize="12sp"
                android:text="嗯那个我今天去了一个很好吃的餐厅然后我们点了很多菜真的很好吃你会推荐什么菜呢" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_api"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="📡 API 润色"
                android:textSize="11sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_local_ai"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="🤖 本地 AI"
                android:textSize="11sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_api_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#E0F7F5"
            android:textSize="11sp"
            android:textColor="#81D8D0"
            android:layout_marginBottom="12dp"
            android:text="API 状态：未测试" />

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 语音与 AI 本地化 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎤 语音与 AI 本地化"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_bridge_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="检测中..."
            android:textSize="11sp"
            android:textColor="#81D8D0"
            android:background="#E0F7F5"
            android:padding="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_hardware_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="硬件检测中..."
            android:textSize="11sp"
            android:textColor="#666666"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="语音模型"
                android:textSize="12sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tv_voice_model_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未安装"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI 润色模型"
                android:textSize="12sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tv_ai_model_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未安装"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_voice"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="⬇ 语音识别"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#81D8D0"
                app:cornerRadius="8dp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_ai"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="⬇ 语音润色"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#81D8D0"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_download_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#81D8D0"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/pb_download"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            android:progressTint="#81D8D0" />

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 主题 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 主题"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_theme_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀️ 当前：明亮模式"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_theme_toggle"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="🌙 切换到黑暗模式"
            android:textSize="12sp"
            android:textColor="#81D8D0"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#81D8D0"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 词库 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 词库"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_dict_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="11sp"
            android:textColor="#666666"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_dict"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="📥下载"
                android:textSize="10sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="6dp"
                android:layout_marginEnd="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_dict"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="📂导入"
                android:textSize="10sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="6dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_dict"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="📤导出"
                android:textSize="10sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="6dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cloud_backup"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="☁️备份"
                android:textSize="10sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="6dp"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 操作按钮 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="💾 保存"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#81D8D0"
                app:cornerRadius="10dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="🔄 重置"
                android:textSize="13sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- 检查更新 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_update"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="🔍 检查更新"
            android:textSize="12sp"
            android:textColor="#81D8D0"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#81D8D0"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 日志 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 运行日志"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:textSize="10sp"
            android:textColor="#666666"
            android:maxLines="10"
            android:scrollbars="vertical"
            android:textIsSelectable="true"
            android:text="等待操作..." />

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
