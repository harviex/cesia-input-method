<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#FFFFFF">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <!-- ═══════════ 新手引导横幅（首次启动显示）═══════════ -->
                <include
                    android:id="@+id/view_onboarding_banner"
                    layout="@layout/view_onboarding_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone" />

                <!-- ═══════════ 标题（可编辑）═══════════ -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_settings_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入法名称"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeColor="@android:color/transparent"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_settings_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:gravity="center"
                        android:inputType="text"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:background="@android:color/transparent"
                        android:padding="8dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="● v1.1.644"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:minHeight="32dp"
                    android:layout_marginBottom="16dp"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/ll_version_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:minHeight="56dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackground">

                    <View
                        android:id="@+id/version_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/version_dot_background" />

                    <TextView
                        android:id="@+id/tv_version_with_dot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.1.644"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:gravity="center" />

                    <ProgressBar
                        android:id="@+id/pb_version_download"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="120dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone"
                        android:progressDrawable="@drawable/progress_bar_horizontal"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0" />
                </LinearLayout>

                <!-- ═══════════ 统计卡片 ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_tiffany"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_stat_input_chars"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#81D8D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="输入字数"
                                android:textSize="10sp"
                                android:textColor="#999999" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#E0E0E0"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_stat_output_chars"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#81D8D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="返回字数"
                                android:textSize="10sp"
                                android:textColor="#999999" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#E0E0E0"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_stat_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#81D8D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="润色次数"
                                android:textSize="10sp"
                                android:textColor="#999999" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 语音统计 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_tiffany"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_stat_voice_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0分钟"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#81D8D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="语音时长"
                                android:textSize="10sp"
                                android:textColor="#999999" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#E0E0E0"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_stat_saved_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0分钟"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#81D8D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="节省时间"
                                android:textSize="10sp"
                                android:textColor="#999999" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="#E0E0E0"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_stat_voice_speed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0字/分"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#81D8D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="输入速度"
                                android:textSize="10sp"
                                android:textColor="#999999" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 历史记录按钮 + 新闻源管理按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_history"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="查看历史记录"
                        android:textSize="13sp"
                        android:textColor="#81D8D0"
                        app:backgroundTint="#FFFFFF"
                        app:strokeColor="#81D8D0"
                        app:strokeWidth="1dp"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_news_sources"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="新闻源管理"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#81D8D0"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <!-- ═══════════ 分隔 ═══════════ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp" />

        <!-- ═══════════ 语音与AI ═══════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="语音与AI"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="长按按钮可卸载模型"
                    android:textSize="10sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_voice"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="语音识别"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:backgroundTint="#81D8D0"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_ai"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="语音润色"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:backgroundTint="#81D8D0"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <!-- 下载进度条（语音识别 / 本地模型） -->
                <ProgressBar
                    android:id="@+id/pb_voice_download"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"
                    android:progressTint="?attr/colorPrimary"
                    android:progressBackgroundTint="#E0F2F1" />

                <ProgressBar
                    android:id="@+id/pb_ai_download"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    android:progressTint="?attr/colorPrimary"
                    android:progressBackgroundTint="#E0F2F1" />

                <!-- ═══════════ 分隔 ═══════════ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <!-- ═══════════ 云端功能设置 ═══════════ -->
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="云端功能设置"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI API URL"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_api_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textSize="12sp"
                android:text="https://openrouter.ai/api/v1/chat/completions" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI API Key"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_openrouter_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 云端模型 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="云端 AI 模型"
            android:textSize="12sp"
            android:textColor="#81D8D0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_cloud_model"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="6dp"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/spinner_bg_white"
            android:textSize="13sp"
            android:textColor="#333333"
            android:text="请选择模型"
            android:drawableEnd="@drawable/ic_expand_more"
            android:drawablePadding="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tavily API Key（互联网搜索）"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_brave_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="12sp"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI 润色 Prompt"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_polish_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="测试要润色的文本"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#81D8D0"
            app:hintTextColor="#81D8D0"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_test_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top"
                android:textSize="12sp"
                android:text="嗯那个我今天去了一个很好吃的餐厅然后我们点了很多菜真的很好吃你会推荐什么菜呢" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_api"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="API 润色"
                android:textSize="11sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_local_ai"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="本地 AI"
                android:textSize="11sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_prompt"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="重置prompt"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#81D8D0"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_api_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textSize="11sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp"
            android:text="API 状态：未测试" />

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />
                <!-- ═══════════ 语音命令词 ═══════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="语音命令词"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="语音输入结尾说出命令词执行"
                    android:textSize="10sp"
                    android:textColor="#999999"
                    android:padding="4dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="智能写作"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxStrokeColor="#81D8D0"
                        app:hintTextColor="#81D8D0"
                        android:layout_marginEnd="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cmd_writing"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="智能修改"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxStrokeColor="#81D8D0"
                        app:hintTextColor="#81D8D0"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cmd_command"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="智能润色"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxStrokeColor="#81D8D0"
                        app:hintTextColor="#81D8D0"
                        android:layout_marginStart="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cmd_polish"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="结束语音识别"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxStrokeColor="#81D8D0"
                        app:hintTextColor="#81D8D0"
                        android:layout_marginEnd="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cmd_finish"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="立即发送"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxStrokeColor="#81D8D0"
                        app:hintTextColor="#81D8D0"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cmd_send"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="退出语音模式"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxStrokeColor="#81D8D0"
                        app:hintTextColor="#81D8D0"
                        android:layout_marginStart="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cmd_exit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_command_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#999999"
                    android:padding="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- ═══════════ 分隔 ═══════════ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <!-- ═══════════ 个性化设置 ═══════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个性化设置"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeColor="#81D8D0"
                    app:hintTextColor="#81D8D0"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_status_idle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:inputType="text"
                        android:hint="输入法状态栏初始状态文字" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeColor="#81D8D0"
                    app:hintTextColor="#81D8D0"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_smart_writing_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:inputType="text"
                        android:hint="长按智能写作按钮显示菜单标题" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeColor="#81D8D0"
                    app:hintTextColor="#81D8D0"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_magic_book_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:inputType="text"
                        android:hint="长按智能修改按钮显示菜单标题" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ═══════════ 分隔 ═══════════ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <!-- ═══════════ 词库 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="词库"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_dict_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="11sp"
            android:textColor="#81D8D0"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pb_dict_download"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            android:progressTint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tv_dict_download_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#81D8D0"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_dict"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="重新下载"
                android:textSize="10sp"
                android:textColor="#81D8D0"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#81D8D0"
                app:strokeWidth="1dp"
                app:cornerRadius="6dp" />
        </LinearLayout>

        <!-- ═══════════ 分隔 ═══════════ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 日志 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="运行日志"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="6dp" />

        <!-- 运行日志区域：点击展开/折叠，无滚动条限制 -->
        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:textSize="11sp"
            android:textColor="#333333"
            android:textIsSelectable="true"
            android:text="等待操作..." />

        <!-- 底部留白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>