<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/popup_bg">

    <!-- 标题栏：统一风格 -->
    <TextView
        android:id="@+id/tv_clipboard_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp"
        android:text="📋 剪贴板管理"
        android:textSize="18sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:background="#E0E0E0" />

    <!-- 搜索栏：统一风格 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="#FAFAFA">

        <EditText
            android:id="@+id/et_clipboard_search"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="🔍 搜索剪贴板..."
            android:textSize="13sp"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:background="@drawable/search_bg"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>

    <!-- 搜索编辑状态提示栏 -->
    <TextView
        android:id="@+id/tv_search_edit_hint"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="12sp"
        android:textColor="#666666"
        android:background="#E0F7FA"
        android:visibility="gone" />

    <!-- 两列网格：与魔法书、智能写作一致 -->
    <GridView
        android:id="@+id/gv_clipboard_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:verticalSpacing="4dp"
        android:horizontalSpacing="4dp"
        android:padding="6dp"
        android:stretchMode="columnWidth"
        android:gravity="top"
        android:listSelector="@android:color/transparent" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tv_clipboard_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="没有找到匹配的内容"
        android:textSize="13sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- 底部管理栏：统一风格 ＋ ⤒ ⊗ ⨯ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <!-- 新增：＋ -->
        <TextView
            android:id="@+id/btn_clipboard_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="＋"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="新增" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 置顶：⤒ -->
        <TextView
            android:id="@+id/btn_clipboard_pin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⤒"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 删除：⊗ -->
        <TextView
            android:id="@+id/btn_clipboard_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⊗"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 关闭：⨯ -->
        <TextView
            android:id="@+id/btn_clipboard_close"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⨯"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="关闭" />

    </LinearLayout>

</LinearLayout>