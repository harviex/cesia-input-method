<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 搜索栏：搜索钮 + 关闭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:background="#F5F5F5">

        <TextView
            android:id="@+id/btn_clipboard_search"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="🔍 点击搜索..."
            android:textSize="13sp"
            android:textColor="#999999"
            android:background="@drawable/search_bg"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_clipboard_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- 搜索编辑状态提示栏 -->
    <TextView
        android:id="@+id/tv_search_edit_hint"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:background="#E3F2FD"
        android:visibility="gone" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tv_clipboard_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="没有找到匹配的内容"
        android:textSize="13sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- 两列网格 -->
    <GridView
        android:id="@+id/gv_clipboard_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:verticalSpacing="4dp"
        android:horizontalSpacing="4dp"
        android:padding="6dp"
        android:stretchMode="columnWidth"
        android:gravity="top"
        android:listSelector="#E0F7FA" />

    <!-- 底部管理栏：置顶 + 删除 + 关闭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/btn_clipboard_pin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📌"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_clipboard_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🗑️"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_clipboard_done"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↩️"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="关闭" />

    </LinearLayout>

</LinearLayout>
