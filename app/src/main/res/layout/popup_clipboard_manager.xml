<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 搜索编辑状态提示栏（仅搜索模式可见） -->
    <TextView
        android:id="@+id/tv_search_edit_hint"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="✏️ 输入搜索关键词...（按发送键确认）"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:background="#E3F2FD"
        android:visibility="gone" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tv_clipboard_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="没有找到匹配的内容"
        android:textSize="13sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- 两列网格 -->
    <GridView
        android:id="@+id/gv_clipboard_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:verticalSpacing="4dp"
        android:horizontalSpacing="4dp"
        android:padding="6dp"
        android:stretchMode="columnWidth"
        android:gravity="top"
        android:listSelector="#E0F7FA" />

    <!-- 底部管理栏：搜索 + 置顶 + 删除 + 关闭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <!-- 搜索按钮：放大镜 -->
        <ImageButton
            android:id="@+id/btn_clipboard_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_search"
            android:scaleType="centerInside"
            android:tint="#555555"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="搜索" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 置顶 -->
        <ImageButton
            android:id="@+id/btn_clipboard_pin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📌"
            android:textSize="14sp"
            android:textColor="#555555"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 删除 -->
        <ImageButton
            android:id="@+id/btn_clipboard_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_delete"
            android:scaleType="centerInside"
            android:tint="#C62828"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 关闭 -->
        <ImageButton
            android:id="@+id/btn_clipboard_done"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            android:tint="#555555"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="关闭" />

    </LinearLayout>

</LinearLayout>
