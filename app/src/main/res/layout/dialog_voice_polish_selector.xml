<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎤 语音识别 + 润色"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Loading 动画（检测中显示） -->
    <LinearLayout
        android:id="@+id/loading_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tv_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在检测后端可用性..."
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- ====== 识别方式 ====== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="识别方式"
        android:textSize="13sp"
        android:textColor="#888888"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/btn_voice_groq"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="4dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="☁️ Groq 云端"
        android:textSize="15sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/btn_voice_whisper"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="4dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="📱 本地 Whisper"
        android:textSize="15sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/btn_voice_google"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="12dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="🌍 Google"
        android:textSize="15sp"
        android:textColor="#333333" />

    <!-- ====== 润色方式 ====== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="润色方式"
        android:textSize="13sp"
        android:textColor="#888888"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/btn_polish_cloud"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="4dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="☁️ 云端润色"
        android:textSize="15sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/btn_polish_local"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="4dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="📱 本地润色"
        android:textSize="15sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/btn_polish_off"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="8dp"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="❌ 关闭润色"
        android:textSize="15sp"
        android:textColor="#333333" />

    <!-- 延迟提示 -->
    <TextView
        android:id="@+id/tv_voice_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#FF8800"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <!-- 按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_voice_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="#E0E0E0"
            android:gravity="center"
            android:text="取消"
            android:textSize="15sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/btn_voice_confirm"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#81D8D8"
            android:gravity="center"
            android:text="🎤 开始录音"
            android:textSize="15sp"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
