<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FAFAFA">

    <!-- RAM 建议 -->
    <TextView
        android:id="@+id/tv_ram_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#888888"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- ====== 识别方式 ====== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="识别方式"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:paddingBottom="4dp" />

    <!-- 第一行：本地识别 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="本地模式"
            android:textSize="11sp"
            android:textColor="#888888"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/btn_whisper_small"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Whisper small"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />

        <TextView
            android:id="@+id/btn_whisper_large"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Whisper large"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />
    </LinearLayout>

    <!-- 第二行：云端识别 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="云端模式"
            android:textSize="11sp"
            android:textColor="#888888"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/btn_google"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Google"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />

        <TextView
            android:id="@+id/btn_groq_asr"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Groq"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />
    </LinearLayout>

    <!-- ====== 润色方式 ====== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="润色方式"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:paddingBottom="4dp" />

    <!-- 第三行：本地润色 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="本地模式"
            android:textSize="11sp"
            android:textColor="#888888"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/btn_qwen_small"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Qwen3.5 small"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />

        <TextView
            android:id="@+id/btn_qwen_large"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Qwen3.5 large"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />
    </LinearLayout>

    <!-- 第四行：云端润色 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="云端模式"
            android:textSize="11sp"
            android:textColor="#888888"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/btn_openrouter"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="OpenRouter"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />

        <TextView
            android:id="@+id/btn_groq_polish"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="Groq"
            android:textSize="12sp"
            android:textColor="#333333"
            android:background="#F0F0F0" />
    </LinearLayout>

    <!-- 下载按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/btn_download_whisper"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⬇ 下载语音模型"
            android:textSize="11sp"
            android:textColor="#666666"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/btn_download_qwen"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="⬇ 下载润色模型"
            android:textSize="11sp"
            android:textColor="#666666"
            android:background="#EEEEEE" />
    </LinearLayout>

    <!-- 确定按钮 -->
    <TextView
        android:id="@+id/btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text=" 确定"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="#81D8D8" />

</LinearLayout>
