<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="12dp">

    <!-- 标题栏 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✂️ 分词结果"
        android:textSize="15sp"
        android:textColor="#81D8D0"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- 原文预览 -->
    <TextView
        android:id="@+id/tv_split_original"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#999999"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="8dp" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="#E0E0E0" />

    <!-- 词列表 -->
    <GridView
        android:id="@+id/gv_words"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="3"
        android:verticalSpacing="6dp"
        android:horizontalSpacing="6dp"
        android:stretchMode="columnWidth"
        android:gravity="top"
        android:listSelector="#E0F7FA" />

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp">

        <!-- 全选 -->
        <TextView
            android:id="@+id/btn_split_select_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⊞ 全选"
            android:textSize="12sp"
            android:textColor="#81D8D0"
            android:background="@drawable/item_click_bg" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 复制选中 -->
        <TextView
            android:id="@+id/btn_split_copy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📋"
            android:textSize="14sp"
            android:textColor="#81D8D0"
            android:enabled="false"
            android:background="@drawable/item_click_bg" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 分享选中 -->
        <TextView
            android:id="@+id/btn_split_share_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📤"
            android:textSize="14sp"
            android:textColor="#81D8D0"
            android:enabled="false"
            android:background="@drawable/item_click_bg" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 搜索选中 -->
        <TextView
            android:id="@+id/btn_split_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🔍"
            android:textSize="14sp"
            android:textColor="#81D8D0"
            android:enabled="false"
            android:background="@drawable/item_click_bg" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 关闭 -->
        <TextView
            android:id="@+id/btn_split_close"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⨯"
            android:textSize="16sp"
            android:textColor="#81D8D0"
            android:background="@drawable/item_click_bg" />

    </LinearLayout>

</LinearLayout>
