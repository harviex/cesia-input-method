<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/popup_bg">

    <!-- 标题栏：与主题设置菜单统一风格（Tiffany色背景，白字，无X按钮） -->
    <LinearLayout
        android:id="@+id/banner_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="-16dp"
        android:layout_marginEnd="-16dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#81D8D0"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" 智能写作"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- 选项区域：2列布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 第一列：剪贴板、RSS源 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/opt_clipboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="○ 📋 剪贴板首条"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="?attr/selectableItemBackground"
                android:tag="clipboard" />

            <TextView
                android:id="@+id/opt_rss_news"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="○ 📰 RSS源"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="?attr/selectableItemBackground"
                android:tag="rss_news" />
        </LinearLayout>

        <!-- 第二列：网络搜索、本地文库 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/opt_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="○ 🌐 网络搜索"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="?attr/selectableItemBackground"
                android:tag="search" />

            <TextView
                android:id="@+id/opt_local_lib"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="○ 📚 本地文库"
                android:textSize="14sp"
                android:textColor="#333333"
                android:background="?attr/selectableItemBackground"
                android:tag="local_lib" />
        </LinearLayout>
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginHorizontal="12dp" />

    <!-- 智能写作命令列表（2列，可滚动，与魔法书一致） -->
    <GridView
        android:id="@+id/gv_smart_records"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:horizontalSpacing="4dp"
        android:verticalSpacing="2dp"
        android:padding="6dp"
        android:scrollbars="vertical"
        android:listSelector="@android:color/transparent"
        android:stretchMode="columnWidth" />

    <!-- 底部按钮栏：＋ 置顶 删除（无关闭X） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <!-- 新增：＋ -->
        <TextView
            android:id="@+id/btn_smart_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="＋"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="新增智能写作命令" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 置顶：⤒ -->
        <TextView
            android:id="@+id/btn_smart_pin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⤒"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 删除：⊗ -->
        <TextView
            android:id="@+id/btn_smart_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⊗"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

    </LinearLayout>

</LinearLayout>
