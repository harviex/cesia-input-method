<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 标题栏：标题 + 关闭按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_model_dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择云端 AI 模型"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center" />

        <TextView
            android:id="@+id/btn_model_dialog_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="⨯"
            android:textSize="20sp"
            android:textColor="#999999"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="关闭" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_model_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:layout_marginBottom="12dp" />

    <!-- 自定义模型 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="自定义模型（填入模型 ID，如 google/gemini-flash-1.5）"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_custom_model"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="模型 ID"
            android:textSize="13sp"
            android:inputType="text" />

        <Button
            android:id="@+id/btn_save_custom_model"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="保存" />
    </LinearLayout>

</LinearLayout>