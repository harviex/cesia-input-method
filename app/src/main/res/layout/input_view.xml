<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 状态栏 -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#EEEEEE"
        android:gravity="center_vertical">

        <View
            android:id="@+id/v_status_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/status_dot_idle"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="就绪"
            android:textSize="11sp"
            android:textColor="#555555"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="设置"
            android:scaleType="centerInside"
            android:padding="4dp" />
    </LinearLayout>

    <!-- 候选词栏：拼音 + 横向滚动候选词 + 展开按钮 -->
    <LinearLayout
        android:id="@+id/candidate_bar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <!-- 横向滚动候选词列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_candidates"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingEnd="4dp" />

        <!-- 展开/收起候选词面板按钮（候选词>4时显示） -->
        <ImageButton
            android:id="@+id/btn_candidate_expand"
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/arrow_down_float"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="2dp"
            android:visibility="gone"
            android:contentDescription="展开候选词" />
    </LinearLayout>

    <!-- 候选词展开面板（多行 GridView，初始隐藏） -->
    <LinearLayout
        android:id="@+id/candidate_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        android:orientation="vertical"
        android:background="#F8F8F8"
        android:visibility="gone">

        <!-- 拼音 + 收起按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tv_panel_composing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#4488FF"
                android:singleLine="true"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btn_panel_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?android:attr/selectableItemBackground"
                android:scaleType="centerInside"
                android:padding="2dp"
                android:contentDescription="收起" />
        </LinearLayout>

        <!-- 候选词网格 5列，超出可滚动，文字自动缩小 -->
        <GridView
            android:id="@+id/gv_candidates"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:numColumns="5"
            android:verticalSpacing="2dp"
            android:horizontalSpacing="2dp"
            android:padding="4dp"
            android:stretchMode="columnWidth"
            android:gravity="center"
            android:listSelector="?android:attr/selectableItemBackground"
            android:scrollbars="vertical"
            android:fastScrollEnabled="false" />
    </LinearLayout>

    <!-- 键盘区域 -->
    <com.cesia.input.CesiaKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8E8E8"
        android:keyTextColor="#333333"
        android:keyBackground="@drawable/key_background"
        android:keyTextSize="13sp"
        android:verticalGap="4dp"
        android:horizontalGap="2dp" />

    <!-- 底部功能按钮栏 -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_magic"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="✨"
            android:textSize="22sp"
            android:textColor="#888888"
            android:backgroundTint="#E0E0E0"
            android:contentDescription="魔法修改"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="3dp"
            app:cornerRadius="8dp" />

        <ImageButton
            android:id="@+id/btn_magic_book"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_edit"
            android:background="@drawable/button_background_gray"
            android:scaleType="centerInside"
            android:contentDescription="魔法记忆"
            android:layout_marginEnd="3dp" />

        <LinearLayout
            android:id="@+id/mic_button_container"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:layout_marginEnd="3dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mic_ai"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="✨润色"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                app:cornerRadius="20dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <View
                android:id="@+id/v_voice_wave"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/voice_wave_anim"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mic_noai"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⚡上屏"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#757575"
                app:cornerRadius="20dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mic"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🎤"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                app:cornerRadius="22dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@drawable/button_background_gray"
            android:scaleType="centerInside"
            android:contentDescription="清空"
            android:layout_marginEnd="3dp" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/button_background_gray"
            android:scaleType="centerInside"
            android:contentDescription="发送" />

    </LinearLayout>

</LinearLayout>
