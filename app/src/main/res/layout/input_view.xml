<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 状态栏 -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#EEEEEE"
        android:gravity="top">

        <View
            android:id="@+id/v_status_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/status_dot_idle"
            android:layout_marginEnd="6dp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="就绪"
            android:textSize="11sp"
            android:textColor="#555555"
            android:maxLines="20"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2" />

        <!-- 键盘切换按钮 -->
        <ImageButton
            android:id="@+id/btn_keyboard_switch"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="键盘切换"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginEnd="2dp" />

        <!-- 剪贴板按钮 -->
        <ImageButton
            android:id="@+id/btn_clipboard_action"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="剪贴板"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginEnd="2dp" />

        <!-- 设置按钮（齿轮图标） -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="设置"
            android:scaleType="centerInside"
            android:padding="4dp" />
    </LinearLayout>

    <!-- 候选词栏（中文模式显示） -->
    <LinearLayout
        android:id="@+id/candidate_bar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#F0F0F0"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_composing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#4488FF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#CCCCCC"
            android:layout_marginEnd="4dp" />

        <TextView android:id="@+id/tv_candidate_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="15sp" android:textColor="#333333" android:background="?android:attr/selectableItemBackground" android:singleLine="true" />
        <TextView android:id="@+id/tv_candidate_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="15sp" android:textColor="#333333" android:background="?android:attr/selectableItemBackground" android:singleLine="true" />
        <TextView android:id="@+id/tv_candidate_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="15sp" android:textColor="#333333" android:background="?android:attr/selectableItemBackground" android:singleLine="true" />
        <TextView android:id="@+id/tv_candidate_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="15sp" android:textColor="#333333" android:background="?android:attr/selectableItemBackground" android:singleLine="true" />
        <TextView android:id="@+id/tv_candidate_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:textSize="15sp" android:textColor="#333333" android:background="?android:attr/selectableItemBackground" android:singleLine="true" />

        <ImageButton
            android:id="@+id/btn_candidate_prev"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_media_previous"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:contentDescription="上一页候选词" />

        <ImageButton
            android:id="@+id/btn_candidate_next"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_media_next"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:contentDescription="下一页候选词" />
    </LinearLayout>

    <!-- 键盘区域 -->
    <com.cesia.input.ui.CustomKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:keyPreviewLayout="@layout/key_preview"
        android:background="#E8E8E8"
        android:keyTextColor="#333333"
        android:keyBackground="@drawable/key_background"
        android:popupLayout="@layout/key_preview"
        android:keyTextSize="13sp"
        android:verticalGap="4dp"
        android:horizontalGap="2dp" />

    <!-- 底部按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="#E0E0E0"
        android:gravity="center_vertical">

        <!-- 重写按钮（点击清除光标前，长按清除光标后） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rewrite"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="0.6"
            android:text="重写"
            android:textSize="11sp"
            android:textColor="#888888"
            android:backgroundTint="#E0E0E0"
            android:contentDescription="重写"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="3dp"
            app:cornerRadius="8dp" />

        <!-- 魔法按钮（语音修改） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_magic"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="0.6"
            android:text="✨"
            android:textSize="20sp"
            android:textColor="#888888"
            android:backgroundTint="#E0E0E0"
            android:contentDescription="语音修改"
            android:stateListAnimator="@null"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="3dp"
            app:cornerRadius="8dp" />

        <!-- 麦克风/语音按钮区域 -->
        <LinearLayout
            android:id="@+id/mic_button_container"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="3"
            android:layout_marginEnd="3dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- AI+ 按钮（录音时显示，左侧） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mic_ai"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="✨润色"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                app:cornerRadius="20dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <!-- 声波动画指示器 -->
            <View
                android:id="@+id/v_voice_wave"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/voice_wave_anim"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <!-- AI× 按钮（录音时显示，右侧） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mic_noai"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⚡上屏"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#757575"
                app:cornerRadius="20dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

            <!-- 主麦克风按钮（默认显示） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mic"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🎤 说话"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                app:cornerRadius="22dp"
                android:elevation="2dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

        <!-- 删除按钮 -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="0.6"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@drawable/button_background_gray"
            android:scaleType="centerInside"
            android:contentDescription="删除" />
    </LinearLayout>

</LinearLayout>
