<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg">

    <!-- 魔法语句列表 -->
    <GridView
        android:id="@+id/gv_magic_items"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:numColumns="2"
        android:horizontalSpacing="0dp"
        android:verticalSpacing="2dp"
        android:padding="6dp"
        android:scrollbars="vertical"
        android:listSelector="@android:color/transparent"
        android:stretchMode="columnWidth" />

    <!-- 底部管理栏：新增 + 置顶 + 删除 + 关闭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <!-- 新增：系统 add 图标 -->
        <ImageButton
            android:id="@+id/btn_add_magic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_add"
            android:scaleType="centerInside"
            android:tint="#1565C0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="新增魔法" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 置顶：emoji 图针改为 pushpin 字符 -->
        <TextView
            android:id="@+id/btn_pin_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📌"
            android:textSize="13sp"
            android:textColor="#555555"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 删除：系统 delete 图标 -->
        <ImageButton
            android:id="@+id/btn_delete_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_delete"
            android:scaleType="centerInside"
            android:tint="#C62828"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 关闭：系统 revert/undo 图标 -->
        <ImageButton
            android:id="@+id/btn_close_magic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            android:tint="#555555"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="关闭" />

    </LinearLayout>

</LinearLayout>
