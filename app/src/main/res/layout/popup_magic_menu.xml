<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg">

    <!-- 标题栏：与主题设置菜单统一风格（Tiffany色背景，白字，无X按钮） -->
    <LinearLayout
        android:id="@+id/banner_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="-16dp"
        android:layout_marginEnd="-16dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#81D8D0"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" 芙莉莲的魔法书"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- 魔法语句列表 -->
    <GridView
    android:id="@+id/gv_magic_items"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
        android:numColumns="2"
        android:horizontalSpacing="0dp"
        android:verticalSpacing="2dp"
        android:padding="6dp"
        android:scrollbars="vertical"
        android:listSelector="@android:color/transparent"
        android:stretchMode="columnWidth" />

    <!-- 底部管理栏：新增 + 置顶 + 删除（无关闭X） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <!-- 新增：+ 符号 -->
        <TextView
            android:id="@+id/btn_add_magic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="＋"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="新增魔法" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 置顶：⤒ 向上箭头到横线（非Emoji图钉） -->
        <TextView
            android:id="@+id/btn_pin_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⤒"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <!-- 删除：清空符号 ⊗ -->
        <TextView
            android:id="@+id/btn_delete_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⊗"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

    </LinearLayout>

</LinearLayout>