<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg">

    <!-- 魔法语句网格 - 可滚动，1列布局（第一项独占一行） -->
    <GridView
        android:id="@+id/gv_magic_items"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:numColumns="1"
        android:horizontalSpacing="2dp"
        android:verticalSpacing="2dp"
        android:padding="6dp"
        android:scrollbars="vertical"
        android:listSelector="@android:color/transparent" />

    <!-- 底部管理栏 5个按钮 - 始终可见 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="4dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/btn_pin_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="📌"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="置顶" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_add_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="➕"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="新增" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_edit_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✏️"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="修改" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_delete_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🗑️"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="删除" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_undo_manage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="↩️"
            android:textSize="15sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="撤销" />

    </LinearLayout>

</LinearLayout>
