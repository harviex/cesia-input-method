    <!-- 第四行：符 中/英 空格 数字 回车 -->
    <Row>
        <Key android:codes="-100" android:keyLabel="符" android:keyEdgeFlags="left" />
        <Key android:codes="-101" android:keyLabel="中" />
        <Key android:codes="32" android:keyLabel="空格" />
        <Key android:codes="-104" android:keyLabel="数" />
        <Key android:codes="10" android:keyLabel="↵" android:keyEdgeFlags="right" />
    </Row>

</Keyboard>
