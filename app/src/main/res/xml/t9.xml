        <Key android:codes="12290" android:keyLabel="。" android:keyEdgeFlags="left" />
        <Key android:codes="52" android:keyLabel="ghi" android:popupCharacters="4" />
        <Key android:codes="53" android:keyLabel="jkl" android:popupCharacters="5" />
        <Key android:codes="54" android:keyLabel="mno" android:popupCharacters="6" />
        <Key android:codes="-109" android:keyLabel="⌦" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第三行：？ pqrs(7) tuv(8) wxyz(9) 0 -->
    <Row>
        <Key android:codes="65311" android:keyLabel="？" android:keyEdgeFlags="left" />
        <Key android:codes="55" android:keyLabel="pqrs" android:popupCharacters="7" />
