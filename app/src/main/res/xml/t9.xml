<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="20%p"
    android:keyHeight="44dp"
    android:horizontalGap="0dp"
    android:verticalGap="0dp">

    <!-- 第一行：， 1 2 3 重写(短按⌫/长按⌦) -->
    <Row>
        <Key android:codes="65292" android:keyLabel="，" android:keyEdgeFlags="left" />
        <Key android:codes="49" android:keyLabel="1" android:popupCharacters="ABC" />
        <Key android:codes="50" android:keyLabel="2" android:popupCharacters="DEF" />
        <Key android:codes="51" android:keyLabel="3" android:popupCharacters="GHI" />
        <Key android:codes="-108" android:keyLabel="⌫" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第二行：。 4 5 6 ⌦ -->
    <Row>
        <Key android:codes="12290" android:keyLabel="。" android:keyEdgeFlags="left" />
        <Key android:codes="52" android:keyLabel="4" android:popupCharacters="JKL" />
        <Key android:codes="53" android:keyLabel="5" android:popupCharacters="MNO" />
        <Key android:codes="54" android:keyLabel="6" android:popupCharacters="PQRS" />
        <Key android:codes="-109" android:keyLabel="⌦" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第三行：？ 7 8 9 0 -->
    <Row>
        <Key android:codes="65311" android:keyLabel="？" android:keyEdgeFlags="left" />
        <Key android:codes="55" android:keyLabel="7" android:popupCharacters="TUV" />
        <Key android:codes="56" android:keyLabel="8" android:popupCharacters="WXYZ" />
        <Key android:codes="57" android:keyLabel="9" />
        <Key android:codes="48" android:keyLabel="0" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第四行：符 中/英 空格 数字 回车 -->
    <Row>
        <Key android:codes="-100" android:keyLabel="符" android:keyEdgeFlags="left" />
        <Key android:codes="-101" android:keyLabel="中" />
        <Key android:codes="32" android:keyLabel="空格" />
        <Key android:codes="-104" android:keyLabel="数" />
        <Key android:codes="10" android:keyLabel="↵" android:keyEdgeFlags="right" />
    </Row>

</Keyboard>
