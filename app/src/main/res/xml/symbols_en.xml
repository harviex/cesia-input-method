<?xml version="1.0" encoding="utf-8"?>
<!--
    英文符号键盘 — 复刻 Trime symbols 键盘
    包含：英文标点 + 符号 + 功能键
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="48dp"
    android:horizontalGap="0dp"
    android:verticalGap="4dp">

    <!-- 第1行：数字键 -->
    <Row>
        <Key android:codes="49" android:keyLabel="1" android:keyEdgeFlags="left" />
        <Key android:codes="50" android:keyLabel="2" />
        <Key android:codes="51" android:keyLabel="3" />
        <Key android:codes="52" android:keyLabel="4" />
        <Key android:codes="53" android:keyLabel="5" />
        <Key android:codes="54" android:keyLabel="6" />
        <Key android:codes="55" android:keyLabel="7" />
        <Key android:codes="56" android:keyLabel="8" />
        <Key android:codes="57" android:keyLabel="9" />
        <Key android:codes="48" android:keyLabel="0" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第2行：~ ! @ # $ ￥ % ^ & * -->
    <Row>
        <Key android:codes="126" android:keyLabel="~"
            android:popupCharacters="`" android:keyEdgeFlags="left" />
        <Key android:codes="33" android:keyLabel="!" />
        <Key android:codes="64" android:keyLabel="@" />
        <Key android:codes="35" android:keyLabel="#" />
        <Key android:codes="36" android:keyLabel="$" />
        <Key android:codes="165" android:keyLabel="￥" />
        <Key android:codes="37" android:keyLabel="%" />
        <Key android:codes="94" android:keyLabel="^" />
        <Key android:codes="38" android:keyLabel="&amp;" />
        <Key android:codes="42" android:keyLabel="*" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第3行：( ) [ ] 「 」 、 \ / : -->
    <Row>
        <Key android:codes="40" android:keyLabel="("
            android:popupCharacters="{" android:keyEdgeFlags="left" />
        <Key android:codes="41" android:keyLabel=")"
            android:popupCharacters="}" />
        <Key android:codes="91" android:keyLabel="["
            android:popupCharacters="【" />
        <Key android:codes="93" android:keyLabel="]"
            android:popupCharacters="】" />
        <Key android:codes="12300" android:keyLabel="「"
            android:popupCharacters="『" />
        <Key android:codes="12301" android:keyLabel="」"
            android:popupCharacters="』" />
        <Key android:codes="12289" android:keyLabel="、"
            android:popupCharacters="\\" />
        <Key android:codes="47" android:keyLabel="/"
            android:popupCharacters="√" />
        <Key android:codes="58" android:keyLabel=":" />
        <Key android:codes="59" android:keyLabel=";" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第4行：+ - = 〈 〉 " ' ， ? -->
    <Row>
        <Key android:codes="43" android:keyLabel="+" android:keyEdgeFlags="left" />
        <Key android:codes="45" android:keyLabel="-"
            android:popupCharacters="_" />
        <Key android:codes="61" android:keyLabel="=" />
        <Key android:codes="12296" android:keyLabel="〈"
            android:popupCharacters="《" />
        <Key android:codes="12297" android:keyLabel="〉"
            android:popupCharacters="》" />
        <Key android:codes="8220" android:keyLabel="&#x201C;"
            android:popupCharacters="&#x201D;" />
        <Key android:codes="8216" android:keyLabel="&#x2018;"
            android:popupCharacters="&#x2019;" />
        <Key android:codes="65292" android:keyLabel="，"
            android:popupCharacters="," />
        <Key android:codes="65311" android:keyLabel="？"
            android:popupCharacters="?" />
    </Row>

    <!-- 第5行：返回 + 退格 + 数字 + 空格 + 句号 + 更多 + 回车 -->
    <Row>
        <Key android:codes="-100" android:keyLabel="ABC"
            android:keyEdgeFlags="left"
            android:keyWidth="12%p" />
        <Key android:codes="-5" android:keyLabel="⌫"
            android:isRepeatable="true"
            android:keyWidth="12%p" />
        <Key android:codes="-102" android:keyLabel="#="
            android:keyWidth="10%p" />
        <Key android:codes="32" android:keyLabel="       "
            android:keyWidth="24%p" />
        <Key android:codes="12290" android:keyLabel="。"
            android:popupCharacters="." />
        <Key android:codes="-103" android:keyLabel="更多"
            android:keyWidth="10%p" />
        <Key android:codes="10" android:keyLabel="↵"
            android:keyEdgeFlags="right"
            android:keyWidth="15%p" />
    </Row>

</Keyboard>
