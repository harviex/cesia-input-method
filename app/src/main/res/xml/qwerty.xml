<?xml version="1.0" encoding="utf-8"?>
<!--
    标准 QWERTY 键盘布局 — 参考 Trime 预设26键
    - 第0行：数字键 1-0（短按输入数字，长按输出符号 !@#$%^&*()）
    - 字母键：短按=拼音输入
    - 字母键副字符：长按输出数字/符号
    - 功能键长按(a/s/d/f/g/h/j/k/l/x/c/v/b/n/m)=编辑功能（全选/Home/End等）
    - 逗号句号：中文标点主字符，英文标点副字符（长按）
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="48dp"
    android:horizontalGap="1dp"
    android:verticalGap="4dp">

    <!-- ===== 第0行：数字行 ===== -->
    <Row>
        <Key android:codes="49" android:keyLabel="1" android:popupCharacters="!" android:keyEdgeFlags="left" />
        <Key android:codes="50" android:keyLabel="2" android:popupCharacters="@" />
        <Key android:codes="51" android:keyLabel="3" android:popupCharacters="#" />
        <Key android:codes="52" android:keyLabel="4" android:popupCharacters="$" />
        <Key android:codes="53" android:keyLabel="5" android:popupCharacters="%" />
        <Key android:codes="54" android:keyLabel="6" android:popupCharacters="^" />
        <Key android:codes="55" android:keyLabel="7" android:popupCharacters="&amp;" />
        <Key android:codes="56" android:keyLabel="8" android:popupCharacters="*" />
        <Key android:codes="57" android:keyLabel="9" android:popupCharacters="(" />
        <Key android:codes="48" android:keyLabel="0" android:popupCharacters=")" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第1行：QWERTY 上排字母 ===== -->
    <Row>
        <Key android:codes="113" android:keyLabel="q" android:popupCharacters="1" android:keyEdgeFlags="left" />
        <Key android:codes="119" android:keyLabel="w" android:popupCharacters="2" />
        <Key android:codes="101" android:keyLabel="e" android:popupCharacters="3" />
        <Key android:codes="114" android:keyLabel="r" android:popupCharacters="4" />
        <Key android:codes="116" android:keyLabel="t" android:popupCharacters="5" />
        <Key android:codes="121" android:keyLabel="y" android:popupCharacters="6" />
        <Key android:codes="117" android:keyLabel="u" android:popupCharacters="7" />
        <Key android:codes="105" android:keyLabel="i" android:popupCharacters="8" />
        <Key android:codes="111" android:keyLabel="o" android:popupCharacters="9" />
        <Key android:codes="112" android:keyLabel="p" android:popupCharacters="0" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第2行：ASDF（功能键长按=编辑功能，popupCharacters=数字备用） ===== -->
    <Row>
        <Key android:codes="97" android:keyLabel="a" android:popupCharacters="1" android:keyEdgeFlags="left"
            android:horizontalGap="5%p" />
        <Key android:codes="115" android:keyLabel="s" android:popupCharacters="2" />
        <Key android:codes="100" android:keyLabel="d" android:popupCharacters="3" />
        <Key android:codes="102" android:keyLabel="f" android:popupCharacters="4" />
        <Key android:codes="103" android:keyLabel="g" android:popupCharacters="5" />
        <Key android:codes="104" android:keyLabel="h" android:popupCharacters="6" />
        <Key android:codes="106" android:keyLabel="j" android:popupCharacters="7" />
        <Key android:codes="107" android:keyLabel="k" android:popupCharacters="8" />
        <Key android:codes="108" android:keyLabel="l" android:popupCharacters="9" />
    </Row>

    <!-- ===== 第3行：Shift + ZXCV + BackSpace ===== -->
    <Row>
        <Key android:codes="-1" android:keyLabel="⇧" android:keyEdgeFlags="left"
            android:isModifier="true"
            android:isSticky="true"
            android:keyWidth="12%p" />
        <Key android:codes="122" android:keyLabel="z" android:popupCharacters="0" />
        <Key android:codes="120" android:keyLabel="x" android:popupCharacters="-" />
        <Key android:codes="99" android:keyLabel="c" android:popupCharacters="=" />
        <Key android:codes="118" android:keyLabel="v" android:popupCharacters="+" />
        <Key android:codes="98" android:keyLabel="b" android:popupCharacters="'" />
        <Key android:codes="110" android:keyLabel="n" android:popupCharacters="&quot;" />
        <Key android:codes="109" android:keyLabel="m" android:popupCharacters="/" />
        <Key android:codes="-5" android:keyLabel="⌫" android:keyEdgeFlags="right"
            android:isRepeatable="true"
            android:keyWidth="15%p" />
    </Row>

    <!-- ===== 第4行：符号切换 + 逗号 + 空格 + 句号 + 回车 ===== -->
    <Row>
        <Key android:codes="-100" android:keyLabel="符" android:keyEdgeFlags="left"
            android:keyWidth="12%p" />
        <Key android:codes="-102" android:keyLabel="数"
            android:keyWidth="10%p" />
        <Key android:codes="44" android:keyLabel="，" android:popupCharacters="," />
        <Key android:codes="32" android:keyLabel="       "
            android:keyWidth="32%p" />
        <Key android:codes="46" android:keyLabel="。" android:popupCharacters="." />
        <Key android:codes="47" android:keyLabel="／" android:popupCharacters="/" />
        <Key android:codes="10" android:keyLabel="↵" android:keyEdgeFlags="right"
            android:keyWidth="12%p" />
    </Row>

</Keyboard>
