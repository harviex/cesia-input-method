<?xml version="1.0" encoding="utf-8"?>
<!--
    中文符号键盘 — 复刻 Trime 中文标点布局
    包含：常用中文标点 + 长按副字符
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="42dp"
    android:horizontalGap="1dp"
    android:verticalGap="4dp">

    <!-- ===== 第1行：常用中文标点 ===== -->
    <Row>
        <Key android:codes="65281" android:keyLabel="！" android:keyEdgeFlags="left"
            android:popupCharacters="‼⁉" />
        <Key android:codes="12290" android:keyLabel="。"
            android:popupCharacters="‥…" />
        <Key android:codes="65292" android:keyLabel="，"
            android:popupCharacters="、" />
        <Key android:codes="65311" android:keyLabel="？"
            android:popupCharacters="⁇" />
        <Key android:codes="65306" android:keyLabel="："
            android:popupCharacters=";" />
        <Key android:codes="65307" android:keyLabel="；"
            android:popupCharacters=":" />
        <Key android:codes="183" android:keyLabel="·"
            android:popupCharacters="•" />
        <Key android:codes="126" android:keyLabel="～"
            android:popupCharacters="〜" />
        <Key android:codes="165" android:keyLabel="¥"
            android:popupCharacters="€£$" />
        <Key android:codes="64" android:keyLabel="＠" android:keyEdgeFlags="right"
            android:popupCharacters="@" />
    </Row>

    <!-- ===== 第2行：书名号 + 引号 ===== -->
    <Row>
        <Key android:codes="12298" android:keyLabel="《" android:keyEdgeFlags="left" />
        <Key android:codes="12299" android:keyLabel="》" />
        <Key android:codes="12300" android:keyLabel="「" />
        <Key android:codes="12301" android:keyLabel="」" />
        <Key android:codes="12302" android:keyLabel="『" />
        <Key android:codes="12303" android:keyLabel="』" />
        <Key android:codes="8220" android:keyLabel="&#x201C;"
            android:popupCharacters="&#x201D;" />
        <Key android:codes="8221" android:keyLabel="&#x201D;"
            android:popupCharacters="&#x201C;" />
        <Key android:codes="8216" android:keyLabel="&#x2018;" />
        <Key android:codes="8217" android:keyLabel="&#x2019;" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第3行：括号 + 数学符号 ===== -->
    <Row>
        <Key android:codes="65313" android:keyLabel="Ⅰ" android:keyEdgeFlags="left"
            android:horizontalGap="5%p"
            android:popupCharacters="ⅡⅢⅣ" />
        <Key android:codes="65317" android:keyLabel="Ⅴ"
            android:popupCharacters="ⅥⅦ" />
        <Key android:codes="40" android:keyLabel="（"
            android:popupCharacters=")" />
        <Key android:codes="41" android:keyLabel="）"
            android:popupCharacters="(" />
        <Key android:codes="91" android:keyLabel="【"
            android:popupCharacters="】" />
        <Key android:codes="93" android:keyLabel="】"
            android:popupCharacters="【" />
        <Key android:codes="123" android:keyLabel="｛"
            android:popupCharacters="｝" />
        <Key android:codes="125" android:keyLabel="｝"
            android:popupCharacters="｛" />
    </Row>

    <!-- ===== 第4行：Shift + 更多符号 + BackSpace ===== -->
    <Row>
        <Key android:codes="-1" android:keyLabel="⇧" android:keyEdgeFlags="left"
            android:isModifier="true"
            android:isSticky="true"
            android:keyWidth="12%p" />
        <Key android:codes="8212" android:keyLabel="—"
            android:popupCharacters="–" />
        <Key android:codes="8230" android:keyLabel="…"
            android:popupCharacters="‥" />
        <Key android:codes="12289" android:keyLabel="、"
            android:popupCharacters="，" />
        <Key android:codes="12304" android:keyLabel="〔"
            android:popupCharacters="〕" />
        <Key android:codes="12305" android:keyLabel="〕"
            android:popupCharacters="〔" />
        <Key android:codes="12288" android:keyLabel="　" />
        <Key android:codes="-5" android:keyLabel="⌫" android:keyEdgeFlags="right"
            android:isRepeatable="true"
            android:keyWidth="15%p" />
    </Row>

    <!-- ===== 第5行：返回QWERTY + 数字 + 空格 + 句号 + 回车 ===== -->
    <Row>
        <Key android:codes="-999" android:keyLabel="⇱ ABC" android:keyEdgeFlags="left"
            android:keyWidth="12%p" />
        <Key android:codes="-102" android:keyLabel="123"
            android:keyWidth="10%p" />
        <Key android:codes="65292" android:keyLabel="，"
            android:popupCharacters="《〈" />
        <Key android:codes="32" android:keyLabel="       "
            android:keyWidth="32%p" />
        <Key android:codes="12290" android:keyLabel="。"
            android:popupCharacters="·…—" />
        <Key android:codes="47" android:keyLabel="/"
            android:popupCharacters="?" />
        <Key android:codes="10" android:keyLabel="↵" android:keyEdgeFlags="right"
            android:keyWidth="12%p" />
    </Row>

</Keyboard>
