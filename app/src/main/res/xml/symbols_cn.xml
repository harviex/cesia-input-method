<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="42dp"
    android:verticalGap="4dp">

    <!-- 第一行：中文标点（原数字键位置） -->
    <Row>
        <Key android:codes="65292" android:keyLabel="，" android:keyEdgeFlags="left" />
        <Key android:codes="12290" android:keyLabel="。" />
        <Key android:codes="12289" android:keyLabel="、" />
        <Key android:codes="65307" android:keyLabel="；" />
        <Key android:codes="65311" android:keyLabel="？" />
        <Key android:codes="65281" android:keyLabel="！" />
        <Key android:codes="65306" android:keyLabel="：" />
        <Key android:codes="8230" android:keyLabel="…" />
        <Key android:codes="8212" android:keyLabel="—" />
        <Key android:codes="12316" android:keyLabel="～" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第二行：括号类 -->
    <Row>
        <Key android:codes="65288" android:keyLabel="（" android:keyEdgeFlags="left" />
        <Key android:codes="65289" android:keyLabel="）" />
        <Key android:codes="12298" android:keyLabel="《" />
        <Key android:codes="12299" android:keyLabel="》" />
        <Key android:codes="12304" android:keyLabel="【" />
        <Key android:codes="12305" android:keyLabel="】" />
        <Key android:codes="12300" android:keyLabel="「" />
        <Key android:codes="12301" android:keyLabel="」" />
        <Key android:codes="12302" android:keyLabel="『" />
        <Key android:codes="12303" android:keyLabel="』" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第三行：英文符号 -->
    <Row>
        <Key android:codes="64" android:keyLabel="@" android:keyEdgeFlags="left" />
        <Key android:codes="35" android:keyLabel="#" />
        <Key android:codes="36" android:keyLabel="$" />
        <Key android:codes="37" android:keyLabel="%" />
        <Key android:codes="94" android:keyLabel="^" />
        <Key android:codes="38" android:keyLabel="&amp;" />
        <Key android:codes="42" android:keyLabel="*" />
        <Key android:codes="45" android:keyLabel="-" />
        <Key android:codes="43" android:keyLabel="+" />
        <Key android:codes="61" android:keyLabel="=" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第四行：更多符号 -->
    <Row>
        <Key android:codes="95" android:keyLabel="_" android:keyEdgeFlags="left" />
        <Key android:codes="124" android:keyLabel="|" />
        <Key android:codes="92" android:keyLabel="\\" />
        <Key android:codes="47" android:keyLabel="/" />
        <Key android:codes="60" android:keyLabel="&lt;" />
        <Key android:codes="62" android:keyLabel="&gt;" />
        <Key android:codes="59" android:keyLabel=";" />
        <Key android:codes="58" android:keyLabel=":" />
        <Key android:codes="34" android:keyLabel="&quot;" />
        <Key android:codes="39" android:keyLabel="'" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第五行：返回 + 英文键盘 + 空格 + 逗号 + 句号 + 退格 + 回车 -->
    <Row>
        <Key android:codes="-999" android:keyLabel="◀" android:keyWidth="12%p" android:keyEdgeFlags="left" />
        <Key android:codes="-100" android:keyLabel="ABC" android:keyWidth="14%p" />
        <Key android:codes="32" android:keyLabel="空格" android:keyWidth="34%p" />
        <Key android:codes="44" android:keyLabel="，" android:keyWidth="10%p" />
        <Key android:codes="46" android:keyLabel="。" android:keyWidth="10%p" />
        <Key android:codes="-5" android:keyLabel="⌫" android:keyWidth="10%p" />
        <Key android:codes="10" android:keyLabel="↵" android:keyWidth="10%p" android:keyEdgeFlags="right" />
    </Row>

</Keyboard>
