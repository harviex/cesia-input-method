<?xml version="1.0" encoding="utf-8"?>
<!--
    数字键盘（T9，默认键盘）— 5×4 布局
    T9拼音输入 + 符号副字符
    主字符（abc/def...）由 CesiaKeyboardView 自定义绘制
    副字符（数字/标点）由 popupCharacters + 红色小字绘制
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="24%p"
    android:keyHeight="42dp"
    android:horizontalGap="5px"
    android:verticalGap="4dp">

    <Row android:keyHeight="52dp">
        <Key android:codes="65292" android:keyLabel="，" android:popupCharacters="&#x201C;" android:keyEdgeFlags="left"
            android:keyWidth="20%p" />
        <Key android:codes="49" android:keyLabel="" android:popupCharacters="1" />
        <Key android:codes="50" android:keyLabel="" android:popupCharacters="2" />
        <Key android:codes="51" android:keyLabel="" android:popupCharacters="3" />
        <Key android:codes="-5" android:keyLabel="⌫" android:isRepeatable="true" android:keyEdgeFlags="right"
            android:keyWidth="20%p" />
    </Row>

    <Row android:keyHeight="52dp">
        <Key android:codes="12290" android:keyLabel="。" android:popupCharacters="." android:keyEdgeFlags="left"
            android:keyWidth="20%p" />
        <Key android:codes="52" android:keyLabel="" android:popupCharacters="4" />
        <Key android:codes="53" android:keyLabel="" android:popupCharacters="5" />
        <Key android:codes="54" android:keyLabel="" android:popupCharacters="6" />
        <Key android:codes="65281" android:keyLabel="！" android:popupCharacters="：" android:keyEdgeFlags="right"
            android:keyWidth="20%p" />
    </Row>

    <Row android:keyHeight="52dp">
        <Key android:codes="-104" android:keyLabel="⇧" android:keyEdgeFlags="left"
            android:keyWidth="20%p" />
        <Key android:codes="55" android:keyLabel="" android:popupCharacters="7" />
        <Key android:codes="56" android:keyLabel="" android:popupCharacters="8" />
        <Key android:codes="57" android:keyLabel="" android:popupCharacters="9" />
        <Key android:codes="65311" android:keyLabel="？" android:popupCharacters="；" android:keyEdgeFlags="right"
            android:keyWidth="20%p" />
    </Row>

    <Row>
        <Key android:codes="-100" android:keyLabel="符" android:keyWidth="15%p" android:keyEdgeFlags="left" />
        <Key android:codes="-999" android:keyLabel="⌨" android:keyWidth="15%p" />
        <Key android:codes="32" android:keyLabel="空格" android:keyHeight="42dp" android:keyWidth="28%p" android:popupCharacters="0" />
        <Key android:codes="-108" android:keyLabel="" android:keyWidth="15%p" />
        <Key android:codes="-109" android:keyLabel="" android:keyWidth="15%p" />
        <Key android:codes="10" android:keyLabel="↵" android:keyWidth="12%p" android:keyEdgeFlags="right" />
    </Row>

</Keyboard>
