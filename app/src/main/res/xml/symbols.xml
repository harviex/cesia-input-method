<?xml version="1.0" encoding="utf-8"?>
<!--
    英文符号键盘 — 重排，与中文符号键盘对齐
    规则：
    - 第1-3行各10个按键，纵横对齐
    - 第4行10个按键（两端对齐）
    - 主字符=常用符号，副字符=对应中文符号
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="9.5%p"
    android:keyHeight="48dp"
    android:horizontalGap="1dp"
    android:verticalGap="4dp">

    <!-- ===== 第1行：常用标点（10键） ===== -->
    <Row>
        <Key android:codes="33" android:keyLabel="!"
            android:popupCharacters="‼" android:keyEdgeFlags="left" />
        <Key android:codes="64" android:keyLabel="@"
            android:popupCharacters="＠" />
        <Key android:codes="35" android:keyLabel="#"
            android:popupCharacters="＃" />
        <Key android:codes="36" android:keyLabel="$"
            android:popupCharacters="￥" />
        <Key android:codes="37" android:keyLabel="%"
            android:popupCharacters="％" />
        <Key android:codes="94" android:keyLabel="^"
            android:popupCharacters="＾" />
        <Key android:codes="38" android:keyLabel="&amp;"
            android:popupCharacters="＆" />
        <Key android:codes="42" android:keyLabel="*"
            android:popupCharacters="＊" />
        <Key android:codes="40" android:keyLabel="("
            android:popupCharacters="（" />
        <Key android:codes="41" android:keyLabel=")"
            android:popupCharacters="）" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第2行：更多标点（10键） ===== -->
    <Row>
        <Key android:codes="95" android:keyLabel="_"
            android:popupCharacters="﹏" android:keyEdgeFlags="left" />
        <Key android:codes="45" android:keyLabel="-"
            android:popupCharacters="—–" />
        <Key android:codes="61" android:keyLabel="="
            android:popupCharacters="＝" />
        <Key android:codes="43" android:keyLabel="+"
            android:popupCharacters="＋" />
        <Key android:codes="91" android:keyLabel="["
            android:popupCharacters="【" />
        <Key android:codes="93" android:keyLabel="]"
            android:popupCharacters="】" />
        <Key android:codes="123" android:keyLabel="{"
            android:popupCharacters="｛" />
        <Key android:codes="125" android:keyLabel="}"
            android:popupCharacters="｝" />
        <Key android:codes="92" android:keyLabel="\\"
            android:popupCharacters="＼" />
        <Key android:codes="124" android:keyLabel="|"
            android:popupCharacters="｜" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第3行：比较+引号（10键） ===== -->
    <Row>
        <Key android:codes="59" android:keyLabel=";"
            android:popupCharacters="；" android:keyEdgeFlags="left" />
        <Key android:codes="58" android:keyLabel=":"
            android:popupCharacters="：" />
        <Key android:codes="39" android:keyLabel="&apos;"
            android:popupCharacters="‘’" />
        <Key android:codes="34" android:keyLabel="&quot;"
            android:popupCharacters="“”" />
        <Key android:codes="44" android:keyLabel=","
            android:popupCharacters="，" />
        <Key android:codes="46" android:keyLabel="."
            android:popupCharacters="。" />
        <Key android:codes="60" android:keyLabel="&lt;"
            android:popupCharacters="《" />
        <Key android:codes="62" android:keyLabel="&gt;"
            android:popupCharacters="》" />
        <Key android:codes="47" android:keyLabel="/"
            android:popupCharacters="／" />
        <Key android:codes="63" android:keyLabel="?"
            android:popupCharacters="？" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第4行：特殊符号（10键） ===== -->
    <Row>
        <Key android:codes="-104" android:keyLabel="⇧"
            android:isSticky="true" android:keyEdgeFlags="left" />
        <Key android:codes="96" android:keyLabel="`"
            android:popupCharacters="·" />
        <Key android:codes="126" android:keyLabel="~"
            android:popupCharacters="～" />
        <Key android:codes="163" android:keyLabel="£"
            android:popupCharacters="￥" />
        <Key android:codes="165" android:keyLabel="¥"
            android:popupCharacters="￥" />
        <Key android:codes="162" android:keyLabel="¢"
            android:popupCharacters="￠" />
        <Key android:codes="8364" android:keyLabel="€"
            android:popupCharacters="€" />
        <Key android:codes="189" android:keyLabel="½"
            android:popupCharacters="1/2" />
        <Key android:codes="188" android:keyLabel="¼"
            android:popupCharacters="1/4" />
        <Key android:codes="-5" android:keyLabel="⌫"
            android:isRepeatable="true" android:keyEdgeFlags="right" />
    </Row>

    <!-- ===== 第5行：返回 + 中英符号切换 + 特殊符号 + 空格 + 回车 ===== -->
    <Row>
        <Key android:codes="-999" android:keyLabel="⇱" android:keyEdgeFlags="left"
            android:keyWidth="12%p" />
        <Key android:codes="-105" android:keyLabel="⇄"
            android:keyWidth="10%p" />
        <Key android:codes="8470" android:keyLabel="№"
            android:popupCharacters="No" />
        <Key android:codes="32" android:keyLabel="       "
            android:keyWidth="32%p" />
        <Key android:codes="191" android:keyLabel="¿"
            android:popupCharacters="?" />
        <Key android:codes="182" android:keyLabel="¶"
            android:popupCharacters="P" />
        <Key android:codes="10" android:keyLabel="↵" android:keyEdgeFlags="right"
            android:keyWidth="12%p" />
    </Row>

</Keyboard>
